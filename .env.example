# ── n8n ──────────────────────────────────────────
N8N_URL=https://n8n.seudominio.com
N8N_API_KEY=sua_api_key_n8n

# ── Evolution API ─────────────────────────────────
EVOLUTION_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=sua_api_key_evolution

# ── Chatwoot ──────────────────────────────────────
CHATWOOT_URL=https://chatwoot.seudominio.com
CHATWOOT_API_KEY=sua_api_key_chatwoot
CHATWOOT_ACCOUNT_ID=1

# ── MongoDB ───────────────────────────────────────
MONGODB_URI=mongodb://user:pass@host:27017
MONGODB_DEFAULT_DB=admin

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://:password@host:6379

# ── Qdrant ───────────────────────────────────────
QDRANT_URL=https://qdrant.seudominio.com
QDRANT_API_KEY=sua_api_key_qdrant

# ── Coolify ──────────────────────────────────────
COOLIFY_URL=https://coolify.seudominio.com
COOLIFY_TOKEN=seu_token_coolify
